# Azure target
AZ_SUBSCRIPTION_ID=
AZ_LOCATION=brazilsouth
AZ_ENV=prod

# Resource names (must be globally unique where required)
AZ_RESOURCE_GROUP=rg-cotation-scrapers-prod
AZ_ACR_NAME=acrcotationscrapersprod
AZ_LOG_ANALYTICS_NAME=log-cotation-scrapers-prod
AZ_CONTAINERAPPS_ENV_NAME=cae-cotation-scrapers-prod
AZ_KEYVAULT_NAME=kv-cotation-scrapers-prod
AZ_STORAGE_ACCOUNT_NAME=stcotscrapersprod
AZ_FILE_SHARE_NAME=cotation-artifacts
AZ_CONTAINERAPP_JOB_NAME=job-cotation-scrapers-prod

# Tagging
AZ_TAG_PROJECT=cotation-scrapers
AZ_TAG_OWNER=data-analytics
AZ_TAG_COST_CENTER=not-set

# Image and job runtime
AZ_IMAGE_NAME=cotation-scrapers
AZ_JOB_CONTAINER_NAME=cotation-scrapers
AZ_JOB_CPU=2.0
AZ_JOB_MEMORY=4Gi
AZ_JOB_REPLICA_TIMEOUT_SEC=18000
AZ_JOB_REPLICA_RETRY_LIMIT=0
AZ_JOB_REPLICA_COMPLETION_COUNT=1
AZ_JOB_PARALLELISM=1

# Schedule (UTC): 07:00 UTC = 04:00 America/Sao_Paulo
AZ_JOB_CRON_UTC=0 7 * * 1-5

# Optional operational config
AZ_ALERT_EMAIL=
SHAREPOINT_GRAPH_TIMEOUT_SEC=30
SHAREPOINT_TRY_CREATE_LINK=TRUE
SHAREPOINT_LINK_SCOPE=anonymous
SHAREPOINT_LINK_TYPE=view
SYNC_BEFORE_CMA_READ=0
LOG_RETENTION_DAYS=14
MANUAL_QUOTES_SOURCE=FILES
